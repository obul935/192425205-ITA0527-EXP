import cv2
import numpy as np

# Read the image (provide your image path)
image = cv2.imread(r"C:\Users\obulr\OneDrive\Pictures\IMG-20250219-WA0034[1].jpg")

# Check if image is loaded
if image is None:
    print("Error: Image not found")
    exit()

rows, cols = image.shape[:2]

# Four points from the original image
pts1 = np.float32([
    [50, 50],
    [cols - 50, 50],
    [50, rows - 50],
    [cols - 50, rows - 50]
])

# Corresponding points in the output image
pts2 = np.float32([
    [0, 0],
    [cols, 0],
    [100, rows],
    [cols - 100, rows]
])

# Get perspective transformation matrix
matrix = cv2.getPerspectiveTransform(pts1, pts2)

# Apply perspective transformation
perspective_image = cv2.warpPerspective(image, matrix, (cols, rows))

# Display images
cv2.imshow("Original Image", image)
cv2.imshow("Perspective Transformed Image", perspective_image)

cv2.waitKey(0)
cv2.destroyAllWindows()
